# MongoDB Atlas connection string
MONGODB_URL=
MONGODB_DB_NAME=repomap

# Redis connection string
REDIS_URL=redis://localhost:6379/0
REPO_CLONE_BASE_DIR=.repo_cache

# Clone timeout in seconds
CLONE_TIMEOUT_SECONDS=120

# App logging
LOG_LEVEL=INFO

# LLM Provider: "groq" or "openrouter"
LLM_PROVIDER=groq

# Groq API settings
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_TIMEOUT_SECONDS=60
GROQ_MODEL_SUMMARIES=llama-3.3-70b-versatile
GROQ_MODEL_FILE_REASONS=meta-llama/llama-4-scout-17b-16e-instruct

TAVILY_API_KEY=
