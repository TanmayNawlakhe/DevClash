# MongoDB Atlas connection string
MONGODB_URL=mongodb+srv://tanmaynawlakhe:devclashdb@cluster0.q547isc.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=repomap

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# Local clone cache for repository analysis
REPO_CLONE_BASE_DIR=.repo_cache

# Clone timeout in seconds
CLONE_TIMEOUT_SECONDS=120

# Redis list key used by worker to consume analysis jobs
ANALYSIS_QUEUE_KEY=analysis_jobs

# App logging
LOG_LEVEL=INFO

# Frontend origins allowed by CORS
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Tavily keyword references
TAVILY_API_KEY=
TAVILY_CACHE_PREFIX=kwref:v1
TAVILY_CACHE_TTL_SECONDS=1209600
TAVILY_LOCK_TTL_SECONDS=15
TAVILY_LOCK_WAIT_MS=2000
